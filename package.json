{
  "name": "coral-reef-ar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:client": "pnpm --filter @reef/client dev",
    "dev:server": "pnpm --filter @reef/server dev",
    "dev": "pnpm -r --parallel dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint packages",
    "test": "pnpm -r test",
    "clean": "pnpm -r exec rm -rf dist node_modules"
  },
  "devDependencies": {
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
